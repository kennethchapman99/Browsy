{
  "workflow_id": "social-platform-upload-schedule",
  "source_system": "external_client",
  "entity_type": "social_post",
  "entity_id": "EXTERNAL_POST_ID",
  "mode": "dry_run",
  "human_gate": true,
  "canonical_payload": {
    "post": {
      "caption": "Example caption.",
      "hashtags": ["example"],
      "location": null,
      "scheduled_publish_at": "2026-08-01T17:00:00Z",
      "target_pages": ["EXTERNAL_PAGE_ID"]
    }
  },
  "assets": [
    { "role": "media_file", "path": "/absolute/path/to/image1.png" },
    { "role": "media_file", "path": "/absolute/path/to/image2.png" }
  ],
  "capture_outputs": [
    "scheduled_post_id",
    "scheduled_status",
    "review_page_screenshot"
  ],
  "on_failure": "stop_and_return_blocked_result",
  "return_contract_version": "automation-result-v1"
}
