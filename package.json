{
  "name": "browsy",
  "version": "0.3.0",
  "description": "Automation harness factory for API, Playwright, and browser agent workflows.",
  "type": "module",
  "bin": {
    "browsy": "src/cli/index.mjs"
  },
  "scripts": {
    "wizard": "node wizard/server.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:browser": "node scripts/smoke-test.mjs --browser",
    "validate:request": "node src/cli/index.mjs validate-request",
    "plan": "node src/cli/index.mjs plan",
    "init:workflow": "node src/cli/index.mjs init",
    "auth:save": "node src/cli/index.mjs auth save",
    "auth:check": "node src/cli/index.mjs auth check",
    "discover": "node src/cli/index.mjs discover",
    "generate:prompt": "node src/cli/index.mjs generate-prompt",
    "run": "node src/cli/index.mjs run",
    "discover:all": "node src/cli/index.mjs discover:all",
    "review": "node src/cli/index.mjs review",
    "feedback": "node src/cli/index.mjs feedback",
    "promote": "node src/cli/index.mjs promote",
    "acceptance:song-flow": "node scripts/acceptance-song-flow.mjs",
    "acceptance:repeat-groups": "node scripts/acceptance-repeat-groups.mjs",
    "acceptance:run-plan": "node scripts/acceptance-run-plan.mjs",
    "acceptance:playwright-executor": "node scripts/acceptance-playwright-executor.mjs",
    "acceptance:automation-package": "node scripts/acceptance-automation-package.mjs",
    "acceptance:generic-repeat-package": "node scripts/acceptance-generic-repeat-package.mjs",
    "acceptance:distrokid-album-example": "node scripts/acceptance-distrokid-album-example.mjs",
    "acceptance:wizard-package-gen": "node scripts/acceptance-wizard-package-gen.mjs",
    "acceptance:distrokid-album-wizard": "node scripts/acceptance-distrokid-album-wizard.mjs",
    "acceptance:project-lifecycle": "node scripts/acceptance-project-lifecycle.mjs",
    "test": "node scripts/acceptance-song-flow.mjs && node scripts/acceptance-repeat-groups.mjs && node scripts/acceptance-run-plan.mjs && node scripts/acceptance-playwright-executor.mjs && node scripts/acceptance-automation-package.mjs && node scripts/acceptance-generic-repeat-package.mjs && node scripts/acceptance-distrokid-album-example.mjs && node scripts/acceptance-wizard-package-gen.mjs && node scripts/acceptance-distrokid-album-wizard.mjs && node scripts/acceptance-project-lifecycle.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "playwright": "^1.56.1"
  }
}
