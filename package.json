{
  "name": "browsy",
  "version": "0.1.0",
  "description": "Automation harness factory for API, Playwright, and OpenClaw-style browser workflows.",
  "type": "module",
  "bin": {
    "browsy": "src/cli/index.mjs"
  },
  "scripts": {
    "smoke": "node scripts/smoke-test.mjs",
    "validate:request": "node src/cli/index.mjs validate-request",
    "init:workflow": "node src/cli/index.mjs init",
    "auth:save": "node src/cli/index.mjs auth save",
    "auth:check": "node src/cli/index.mjs auth check",
    "discover": "node src/cli/index.mjs discover",
    "generate:prompt": "node src/cli/index.mjs generate-prompt",
    "run": "node src/cli/index.mjs run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "playwright": "^1.56.1"
  }
}
