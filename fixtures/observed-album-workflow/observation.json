{
  "schemaVersion": "browsy.observation.v1",
  "workflowId": "observed-album-upload",
  "title": "Observed album upload",
  "goal": "Use an observed browser walkthrough to model a generic album upload with repeated tracks, captured outputs, and manual final submit checkpoints.",
  "pages": [
    {
      "id": "albumCreate",
      "purpose": "Create album release",
      "url": "https://example.invalid/releases/new",
      "notes": "Initial page observed in browser."
    },
    {
      "id": "releaseDetail",
      "purpose": "Generated release detail page",
      "urlTemplate": "https://example.invalid/releases/{{releaseId}}",
      "exampleUrl": "https://example.invalid/releases/REL_ABC123",
      "captureAfter": "create-release",
      "notes": "Release ID appears in URL after the create action."
    }
  ],
  "fields": [
    {
      "id": "albumTitle",
      "label": "Album title",
      "type": "text",
      "scope": "global",
      "exampleValue": "Sunrise Sessions"
    },
    {
      "id": "artistName",
      "label": "Artist name",
      "type": "text",
      "scope": "global",
      "exampleValue": "Example Artist"
    },
    {
      "id": "releaseDate",
      "label": "Release date",
      "type": "date",
      "scope": "global",
      "exampleValue": "2099-06-01"
    },
    {
      "id": "primaryGenre",
      "label": "Primary genre",
      "type": "select",
      "scope": "global",
      "exampleValue": "Indie Pop"
    },
    {
      "id": "albumCover",
      "label": "Album cover",
      "type": "file",
      "scope": "asset",
      "exampleValue": "./album-cover.png"
    },
    {
      "id": "songwriter",
      "label": "Songwriter",
      "type": "text",
      "scope": "default",
      "exampleValue": "Example Artist"
    }
  ],
  "repeatGroups": [
    {
      "id": "tracks",
      "label": "Tracks",
      "itemLabel": "track",
      "source": "folder_manifest",
      "addAction": {
        "id": "addTrack",
        "label": "Add another track",
        "type": "click",
        "scope": "repeat-add",
        "targetRepeatGroup": "tracks",
        "selectorHint": "[data-browsy-action='add-track']"
      },
      "itemFields": [
        {
          "id": "trackTitle",
          "label": "Track title",
          "type": "text",
          "exampleValue": "Morning Light"
        },
        {
          "id": "trackNumber",
          "label": "Track number",
          "type": "number",
          "exampleValue": 1
        },
        {
          "id": "explicitLyrics",
          "label": "Explicit lyrics",
          "type": "checkbox",
          "exampleValue": false
        }
      ],
      "itemAssets": [
        {
          "id": "audioFile",
          "label": "Audio file",
          "type": "file",
          "exampleValue": "./tracks/01-morning-light.wav"
        }
      ]
    }
  ],
  "actions": [
    {
      "id": "createRelease",
      "label": "Create release draft",
      "type": "click",
      "selectorHint": "[data-browsy-action='create-release']",
      "manualOnly": false
    },
    {
      "id": "addTrack",
      "label": "Add another track",
      "type": "click",
      "scope": "repeat-add",
      "targetRepeatGroup": "tracks",
      "selectorHint": "[data-browsy-action='add-track']",
      "manualOnly": false
    },
    {
      "id": "finalSubmit",
      "label": "Submit release to stores",
      "type": "click",
      "selectorHint": "[data-browsy-action='final-submit']",
      "manualOnly": true,
      "safetyCategory": "final submission"
    }
  ],
  "capturedOutputs": [
    {
      "id": "releaseId",
      "label": "Release ID",
      "scope": "captured",
      "source": "current_url",
      "regex": "/releases/(REL_[A-Z0-9_]+)",
      "required": true,
      "captureAfter": "create-release",
      "example": "REL_ABC123"
    },
    {
      "id": "publicReleaseUrl",
      "label": "Public release URL",
      "scope": "external_link",
      "source": "selector_attribute",
      "selector": "[data-browsy-output='public-release-url']",
      "attribute": "href",
      "required": true,
      "captureAfter": "publish-link-generated",
      "example": "https://example.invalid/public/sunrise-sessions",
      "verify": {
        "type": "manual_or_http_status"
      }
    }
  ],
  "humanCheckpoints": [
    {
      "id": "reviewBeforeFinalSubmit",
      "label": "Review all album and track details before final submit",
      "beforeAction": "finalSubmit"
    },
    {
      "id": "reviewCapturedPublicLink",
      "label": "Verify captured public release URL before downstream marketing"
    }
  ],
  "notes": "Generic fixture. It intentionally avoids vendor-specific site names or local product paths."
}
